#!/usr/bin/expect -f
set timeout 30
set password "kent...."
set ip "157.173.101.159"
set user "user246"

spawn ssh-copy-id -o StrictHostKeyChecking=no $user@$ip
expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    "Are you sure you want to continue connecting" {
        send "yes\r"
        exp_continue
    }
    eof
}
